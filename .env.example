# Copy this file to `.env` and fill in your keys.

# Sarvam — used for STT (Saaras) and TTS (Bulbul). Required.
# Get a key at https://dashboard.sarvam.ai (₹1000 free credits).
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Gemini — used for the LLM brain. Gemini 2.5 Flash is used for its speed
# (~500ms first token) and large context window (1M tokens).
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: force mock mode if both keys are missing (UI-only demo).
USE_MOCK=false

# Default voice and language. Overridable from the UI.
DEFAULT_LANGUAGE=en-IN
DEFAULT_VOICE=anand

# ── Session logging + email notifications ──────────────────────────────────
# When a session ends, Aarav emails a transcript to NOTIFY_EMAIL.
# Leave blank to skip email (file logging to logs/sessions/ always happens).
NOTIFY_EMAIL=your@email.com
GMAIL_FROM=your@gmail.com          # Gmail address that sends the email
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx  # 16-char Gmail App Password (not your login password)
                                        # Generate at: myaccount.google.com → Security → App passwords

# Admin view: GET /admin/sessions?token=<ADMIN_TOKEN>
# Pick any random string — this is the password for the session admin page.
ADMIN_TOKEN=change_me_to_something_secret
